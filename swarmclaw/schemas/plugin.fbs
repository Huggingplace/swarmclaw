namespace swarmclaw_plugin;

table PluginRequest {
  /// The specific tool the host wants the plugin to execute
  tool_name: string;
  
  /// The JSON arguments generated by the LLM
  arguments_json: string;
  
  /// Optional raw binary payload (Zero-copy for images/video)
  binary_payload: [ubyte];
}

table PluginResponse {
  success: bool;
  
  /// A JSON string returned to the LLM context
  result_json: string;
  
  /// Optional binary artifact generated by the plugin (e.g., an altered image)
  binary_artifact: [ubyte];
  
  /// If success=false, provide the error here
  error_message: string;
}

table PluginManifest {
  /// The name of the skill
  name: string;
  
  /// The description of the skill for the LLM
  description: string;
  
  /// A JSON schema describing all the tools this plugin provides
  tools_json: string;
  
  /// The host capabilities required by this plugin (e.g., "http:api.github.com", "fs:read")
  capabilities: [string];
}

root_type PluginRequest;